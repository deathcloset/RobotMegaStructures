# ── Sim server (packages/server) ──
# Bind address & port. Prod: 127.0.0.1 (behind Caddy). Dev: 0.0.0.0 is convenient.
HOST=0.0.0.0
PORT=8080

# Tick / broadcast rates — §7.4 starting values, meant to be tuned in Phase 0.
TICK_HZ=10
BROADCAST_HZ=4

# Snapshot encoding: the primary egress lever (§7.2). full | delta
SNAPSHOT_MODE=full
# In delta mode, force a full keyframe at least this often (ms).
KEYFRAME_INTERVAL_MS=5000

# Artificial OUTBOUND latency injection for the ~1s-lag feel test (0 = off).
LAG_MS=0
JITTER_MS=0

# NPC robots the server seeds so the site is never empty.
SEED_ROBOTS=8
# How many of those are autonomous BUILDER bots (run the build loop); the rest
# just wander. Builders make the worksite feel alive and the contract self-loop.
SEED_BUILDERS=5
# How many of the builders are PROSPECTORS that source material by mining the
# planet's ore veins instead of the convenient depots (<= SEED_BUILDERS).
SEED_MINERS=2

# Metrics summary log cadence (ms).
METRICS_LOG_MS=5000

# Disconnect grace window (ms): a dropped robot stays parked + reclaimable this
# long before removal (§4.7 — reconnection is the common case on cheap phones).
GRACE_PERIOD_MS=120000

# ── Client (packages/client, Vite) ──
# Override the WebSocket URL the browser connects to. If unset:
#   dev  -> ws://localhost:8080/ws
#   prod -> derived from page origin (wss://<host>/ws), matching the Caddy setup.
# VITE_WS_URL=ws://localhost:8080/ws

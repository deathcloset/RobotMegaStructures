# Installed to /etc/rms/server.env by provision.sh. Edit, then: systemctl restart rms-server
HOST=127.0.0.1
PORT=8080
TICK_HZ=10
BROADCAST_HZ=4
SNAPSHOT_MODE=full
KEYFRAME_INTERVAL_MS=5000
LAG_MS=0
JITTER_MS=0
SEED_ROBOTS=12
METRICS_LOG_MS=5000
# Disconnect grace window (ms): a dropped robot stays parked + reclaimable this
# long before removal (§4.7). Default 120000 (2 min) — generous for phone naps.
GRACE_PERIOD_MS=120000

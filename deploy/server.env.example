# Installed to /etc/rms/server.env by provision.sh. Edit, then: systemctl restart rms-server
HOST=127.0.0.1
PORT=8080
TICK_HZ=10
BROADCAST_HZ=4
SNAPSHOT_MODE=full
KEYFRAME_INTERVAL_MS=5000
LAG_MS=0
JITTER_MS=0
# NPCs seeded PER SECTION (the world is now a grid of sections). Keep this below
# SECTION_CAPACITY so each section leaves room for visitors + roaming bots.
SEED_ROBOTS=6
# How many of those are autonomous builder bots (the rest wander between sections).
SEED_BUILDERS=4
# How many of the builders prospect ore veins instead of using depots.
SEED_MINERS=2
# OSHA cap: max robots in one section before the checkpoint queues arriving bots
# (§4.4). Players are never blocked; this throttles the autonomous swarm.
SECTION_CAPACITY=12
# Hard cap of the nested zone — a capped interior chamber (a "VAULT") you opt into
# through its gate (§4.4). Unlike a section, this caps PLAYERS too: a full chamber
# queues you at the gate. A resident crew fills cap-1; set 2-3 to feel the queue.
NESTED_ZONE_CAP=3
METRICS_LOG_MS=5000
# Disconnect grace window (ms): a dropped robot stays parked + reclaimable this
# long before removal (§4.7). Default 120000 (2 min) — generous for phone naps.
GRACE_PERIOD_MS=120000
